{
  "name": "@moy/config",
  "version": "1.0.0",
  "private": true,
  "description": "MOY 共享工程配置：TypeScript / ESLint / Prettier 基线",
  "type": "module",
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./eslint": "./eslint.config.js",
    "./prettier": "./prettier.config.js"
  },
  "files": [
    "tsconfig.base.json",
    "eslint.config.js",
    "prettier.config.js"
  ],
  "scripts": {
    "lint": "echo \"@moy/config: skip (config package)\" && exit 0",
    "typecheck": "echo \"@moy/config: skip (config package)\" && exit 0",
    "test": "echo \"@moy/config: skip (config package)\" && exit 0",
    "test:unit": "echo \"@moy/config: skip (config package)\" && exit 0"
  },
  "dependencies": {
    "@eslint/js": "^9.12.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  }
}
