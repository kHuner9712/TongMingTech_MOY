# =============================================================================
# MOY 本地开发环境变量样例
# 复制为 .env 并按需修改。生产环境禁止使用本文件中的默认值。
# =============================================================================

# --- 运行环境 ---
NODE_ENV=development

# --- 基础服务（由 docker-compose.yml 提供）---
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=moy
POSTGRES_USER=moy
POSTGRES_PASSWORD=moy_dev_password
DATABASE_URL=postgresql://moy:moy_dev_password@localhost:5432/moy?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- API 服务 ---
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_URL=http://localhost:4000
API_LOG_LEVEL=debug

# --- Web 服务 ---
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- 鉴权与加密 ---
# 至少 32 字符随机字符串，生产环境必须重新生成
JWT_SECRET=replace-me-with-a-32-char-min-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_PEPPER=replace-me-with-random-pepper

# --- 多租户隔离 ---
# strict = 每次请求必须携带租户上下文；permissive = 仅日志告警（仅开发用）
TENANT_ISOLATION_MODE=strict

# --- 任务队列 ---
BULLMQ_CONCURRENCY=4

# --- LLM Provider（阶段 0 仅占位，业务模块开发时启用）---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=30000

# --- 文件存储 ---
# local | s3
FILE_STORAGE_DRIVER=local
FILE_STORAGE_LOCAL_DIR=./storage
# S3（可选）
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- 审计日志 ---
AUDIT_LOG_RETENTION_DAYS=365
